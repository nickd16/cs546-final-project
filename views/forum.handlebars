<div>
    <h1>Forum</h1>

    {{#if error}}
    <p class="error">{{error}}</p>
    {{/if}}

    <p>
        <button type="button" id="forumNewPostOpen">New post</button>
        <a href="/forum?mine=1">Your posts</a>
        <a href="/forum">All posts</a>
    </p>

    <form method="get" action="/forum">
        {{#if mine}}<input type="hidden" name="mine" value="1">{{/if}}
        <p>Filter:</p>
        <select name="catagoryFilter">
            <option value="all" {{#if isAll}}selected{{/if}}>All</option>
            <option value="tennis" {{#if isTennis}}selected{{/if}}>Tennis</option>
            <option value="basketball" {{#if isBasketball}}selected{{/if}}>Basketball</option>
            <option value="handball" {{#if isHandball}}selected{{/if}}>Handball</option>
            <option value="hiking" {{#if isHiking}}selected{{/if}}>Hiking</option>
        </select>
        <p>Search:</p>
        <input type="text" name="q" value="{{qText}}">
        <p>
            <button type="submit">Apply</button>
            <a href="/forum">Clear</a>
        </p>
    </form>

    <h2>Posts</h2>
    {{#if posts.length}}
    <ul>
        {{#each posts}}
        <li>
            <p><strong>{{catagory}}</strong> — {{dateTimeLabel}}</p>
            <h3>{{title}}</h3>
            <p>By {{authorUsername}}</p>
            <p>{{body}}</p>
            <p>
                {{#if isDeleted}}
                <button type="button" disabled>Like ({{likeCount}})</button>
                <button type="button" disabled>Dislike ({{dislikeCount}})</button>
                {{else}}
                <form action="/forum/{{_idStr}}/like" method="post">
                    <button type="submit">Like ({{likeCount}})</button>
                </form>
                <form action="/forum/{{_idStr}}/dislike" method="post">
                    <button type="submit">Dislike ({{dislikeCount}})</button>
                </form>
                {{/if}}
                {{#if isMine}}
                <form action="/forum/{{_idStr}}/delete" method="post">
                    <button type="submit">Delete</button>
                </form>
                {{/if}}
                {{#if isDeleted}}
                <button type="button" disabled>Report</button>
                {{else}}
                <button type="button" class="forumReportOpen" data-postid="{{_idStr}}">Report</button>
                {{/if}}
            </p>
            <p>Comments:</p>
            {{#unless isDeleted}}
            <form action="/forum/{{_idStr}}/comment" method="post">
                <input type="hidden" name="parentId" value="">
                <p>
                    <label for="forum-new-comment-{{_idStr}}">Add a comment</label><br>
                    <textarea id="forum-new-comment-{{_idStr}}" name="body" rows="3" maxlength="5000" required></textarea>
                </p>
                <p><button type="submit">Post comment</button></p>
            </form>
            {{/unless}}

            <div class="commentTree">
                {{#each commentTree}}
                    {{> comment}}
                {{/each}}
            <div>

            <hr>
        </li>
        {{/each}}
    </ul>
    {{else}}
    <p>No posts yet.</p>
    {{/if}}

    <dialog id="forumNewPostDialog">
        <h2>New post</h2>
        <form action="/forum" method="post">
            <p>
                <label for="forum-title">Title</label><br>
                <input id="forum-title" name="title" type="text" maxlength="200" required>
            </p>
            <p>
                <label for="forum-category">Category</label><br>
                <select id="forum-category" name="catagory" required>
                    <option value="all">All</option>
                    <option value="tennis">Tennis</option>
                    <option value="basketball">Basketball</option>
                    <option value="handball">Handball</option>
                    <option value="hiking">Hiking</option>
                </select>
            </p>
            <p>
                <label for="forum-body">Body</label><br>
                <textarea id="forum-body" name="body" rows="6" maxlength="10000" required></textarea>
            </p>
            <p>
                <button type="submit">Post</button>
                <button type="button" id="forumNewPostCancel">Cancel</button>
            </p>
        </form>
    </dialog>

    <dialog id="forumReplyDialog">
        <h2>Reply</h2>
        <form id="forumReplyForm" action="/forum/POST_ID/comment" method="post">
            <input type="hidden" name="parentId" id="forum-reply-parentid" value="">
            <p>
                <label for="forum-reply-body">Your reply</label><br>
                <textarea id="forum-reply-body" name="body" rows="4" maxlength="5000" required></textarea>
            </p>
            <p>
                <button type="submit">Reply</button>
                <button type="button" id="forumReplyCancel">Cancel</button>
            </p>
        </form>
    </dialog>

    <dialog id="forumCommentReportDialog">
        <h2>Report comment</h2>
        <form id="forumCommentReportForm" action="/forum/POST_ID/comment/COMMENT_ID/report" method="post">
            <p>
                <label for="forum-comment-report-reason">Why are you reporting?</label><br>
                <select id="forum-comment-report-reason" name="reason" required>
                    <option value="spam">Spam</option>
                    <option value="harassment">Harassment</option>
                    <option value="hate">Hate</option>
                    <option value="violence">Violence</option>
                    <option value="other">Other</option>
                </select>
            </p>
            <p>
                <label for="forum-comment-report-description">Description</label><br>
                <textarea id="forum-comment-report-description" name="description" rows="4" maxlength="2000"></textarea>
            </p>
            <p>
                <button type="submit">Submit report</button>
                <button type="button" id="forumCommentReportCancel">Cancel</button>
            </p>
        </form>
    </dialog>

    <dialog id="forumReportDialog">
        <h2>Report</h2>
        <form id="forumReportForm" action="/forum/POST_ID/report" method="post">
            <p>
                <label for="forum-report-reason">Why are you reporting?</label><br>
                <select id="forum-report-reason" name="reason" required>
                    <option value="spam">Spam</option>
                    <option value="harassment">Harassment</option>
                    <option value="hate">Hate</option>
                    <option value="violence">Violence</option>
                    <option value="other">Other</option>
                </select>
            </p>
            <p>
                <label for="forum-report-description">Description</label><br>
                <textarea id="forum-report-description" name="description" rows="4" maxlength="2000"></textarea>
            </p>
            <p>
                <button type="submit">Submit report</button>
                <button type="button" id="forumReportCancel">Cancel</button>
            </p>
        </form>
    </dialog>

    <script>
    (function () {
      var dlg = document.getElementById('forumNewPostDialog');
      var openBtn = document.getElementById('forumNewPostOpen');
      var cancelBtn = document.getElementById('forumNewPostCancel');
      if (openBtn && dlg && dlg.showModal) openBtn.addEventListener('click', function () { dlg.showModal(); });
      else if (openBtn && dlg) openBtn.addEventListener('click', function () { dlg.setAttribute('open', ''); });
      if (cancelBtn && dlg && dlg.close) cancelBtn.addEventListener('click', function () { dlg.close(); });
      else if (cancelBtn && dlg) cancelBtn.addEventListener('click', function () { dlg.removeAttribute('open'); });

      var reportDlg = document.getElementById('forumReportDialog');
      var reportForm = document.getElementById('forumReportForm');
      var reportCancel = document.getElementById('forumReportCancel');
      var reportButtons = document.getElementsByClassName('forumReportOpen');
      for (var i = 0; i < reportButtons.length; i++) {
        reportButtons[i].addEventListener('click', function (e) {
          var postId = this.getAttribute('data-postid');
          if (reportForm && postId) reportForm.setAttribute('action', '/forum/' + postId + '/report');
          if (reportDlg && reportDlg.showModal) reportDlg.showModal();
          else if (reportDlg) reportDlg.setAttribute('open', '');
        });
      }
      if (reportCancel && reportDlg && reportDlg.close) reportCancel.addEventListener('click', function () { reportDlg.close(); });
      else if (reportCancel && reportDlg) reportCancel.addEventListener('click', function () { reportDlg.removeAttribute('open'); });

      var replyDlg = document.getElementById('forumReplyDialog');
      var replyForm = document.getElementById('forumReplyForm');
      var replyParentInput = document.getElementById('forum-reply-parentid');
      var replyCancel = document.getElementById('forumReplyCancel');
      var replyButtons = document.getElementsByClassName('forumReplyOpen');
      for (var r = 0; r < replyButtons.length; r++) {
        replyButtons[r].addEventListener('click', function () {
          var pid = this.getAttribute('data-postid');
          var cid = this.getAttribute('data-commentid');
          if (replyForm && pid) replyForm.setAttribute('action', '/forum/' + pid + '/comment');
          if (replyParentInput && cid) replyParentInput.value = cid;
          if (replyDlg && replyDlg.showModal) replyDlg.showModal();
          else if (replyDlg) replyDlg.setAttribute('open', '');
        });
      }
      if (replyCancel && replyDlg && replyDlg.close) replyCancel.addEventListener('click', function () { replyDlg.close(); });
      else if (replyCancel && replyDlg) replyCancel.addEventListener('click', function () { replyDlg.removeAttribute('open'); });

      var commentReportDlg = document.getElementById('forumCommentReportDialog');
      var commentReportForm = document.getElementById('forumCommentReportForm');
      var commentReportCancel = document.getElementById('forumCommentReportCancel');
      var commentReportButtons = document.getElementsByClassName('forumCommentReportOpen');
      for (var c = 0; c < commentReportButtons.length; c++) {
        commentReportButtons[c].addEventListener('click', function () {
          var pid = this.getAttribute('data-postid');
          var cid = this.getAttribute('data-commentid');
          if (commentReportForm && pid && cid) commentReportForm.setAttribute('action', '/forum/' + pid + '/comment/' + cid + '/report');
          if (commentReportDlg && commentReportDlg.showModal) commentReportDlg.showModal();
          else if (commentReportDlg) commentReportDlg.setAttribute('open', '');
        });
      }
      if (commentReportCancel && commentReportDlg && commentReportDlg.close) commentReportCancel.addEventListener('click', function () { commentReportDlg.close(); });
      else if (commentReportCancel && commentReportDlg) commentReportCancel.addEventListener('click', function () { commentReportDlg.removeAttribute('open'); });
    })();
    </script>
</div>
